# Copy this file to .env.local and fill in your own keys.
# Both APIs have free tiers — see README for details.

# Hugging Face Inference API — free, no card required
# Get a key at https://huggingface.co/settings/tokens
VITE_HF_API_KEY=your-key

# Gemini API (Flash-Lite model) — free tier, no card required
# Get a key at https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=your-key
